{
  "name": "mireditor",
  "version": "0.0.1",
  "main": "main.electron.js",
  "author": "Efe Bilgin",
  "description": "Mireditor - Graphics Engine",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "npx electron .",
    "backend": "cd ../backend && python -m uvicorn main:app --reload --port 8000",
    "dev-desktop": "concurrently -n BACK,VITE,ELEC -c blue,green,magenta \"cd ../backend && python -m uvicorn main:app --reload --port 8000\" \"vite --port 5173\" \"npx wait-on http://localhost:5173 http-get://localhost:8000/health && npx electron .\"",
    "build-exe": "vite build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.mireditor.app",
    "productName": "Mireditor",
    "directories": {
      "output": "build-output"
    },
    "files": [
      "dist/**/*",
      "main.electron.js",
      "preload-splash.js",
      "splash.html",
      "assets/**/*",
      "package.json"
    ],
    "extraFiles": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "axios": "^1.13.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "private": true
}
