{
  "name": "mireditor",
  "version": "0.0.4",
  "main": "main.electron.js",
  "author": "Efe Bilgin",
  "description": "Mireditor - Graphics Engine",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "npx electron .",
    "backend": "cd ../backend && python -m uvicorn main:app --reload --port 8000",
    "dev-desktop": "concurrently -n BACK,VITE,ELEC -c blue,green,magenta \"cd ../backend && python -m uvicorn main:app --reload --port 8000\" \"vite --port 5173\" \"npx wait-on http://localhost:5173 http-get://localhost:8000/health && npx electron .\"",
    "build-exe": "vite build && electron-builder --win --x64 --config electron-builder.json",
    "build-exe-signed": "vite build && set CSC_LINK=./cert/mireditor-signing.pfx&& set CSC_KEY_PASSWORD=mireditor2026&& electron-builder --win --x64 --config electron-builder.json",
    "create-cert": "powershell -ExecutionPolicy Bypass -File scripts/create-cert.ps1"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "fabric": "^6.9.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
