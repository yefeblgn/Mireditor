{
  "name": "mireditor",
  "version": "0.2.0",
  "main": "main.electron.js",
  "author": "Efe Bilgin",
  "description": "Mireditor - Graphics Engine",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "npx electron .",
    "typecheck": "tsc --noEmit",
    "backend": "cd ../backend && python main.py",
    "dev-desktop": "concurrently -n BACK,VITE,ELEC -c blue,green,magenta \"cd ../backend && python main.py\" \"vite --port 5173\" \"npx wait-on http://localhost:5173 && npx electron .\"",
    "build-exe": "vite build && electron-builder --win --x64 --config electron-builder.json"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.17.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.8",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@types/react-dom": "~19.2.2",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
