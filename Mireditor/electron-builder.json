{
  "appId": "com.mireditor.app",
  "productName": "Mireditor",
  "directories": {
    "output": "release2"
  },
  "files": [
    "dist/**/*",
    "main.electron.js",
    "discord-rpc-manager.js",
    "preload-splash.js",
    "splash.html",
    "assets/**/*",
    "package.json"
  ],
  "publish": {
    "provider": "github",
    "owner": "yefeblgn",
    "repo": "Mireditor"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "assets/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "runAfterFinish": true,
    "deleteAppDataOnUninstall": false,
    "include": "installer.nsh"
  }
}
