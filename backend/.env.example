# Mireditor Backend — ortam değişkenleri örneği
# Bu dosyayı `.env` olarak kopyalayın ve değerleri doldurun.
# NOT: Uygulama local-first çalışır; backend opsiyoneldir.
# Veritabanı yoksa uygulama çevrimdışı modda tam çalışmaya devam eder.

PORT=3000

# MySQL bağlantısı (opsiyonel — hesap/senkron özellikleri için)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=mireditor

# JWT (auth endpoint'leri uygulandığında)
JWT_SECRET=change-me-in-production
